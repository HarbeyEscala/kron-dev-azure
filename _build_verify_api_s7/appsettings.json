{
  "DatabaseSettings": {
    "ConnectionString": "Server=localhost;Database=KronCountingDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "JwtSettings": {
    "Issuer": "Kron.Counting",
    "Audience": "Kron.Counting.Client",
    "SecretKey": "KronCountingSuperSecretJwtKeyForDevelopment2026Only!",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 30
  },

  "RedisSettings": {
    "ConnectionString": "",
    "InstanceName": "KronCounting"
  },

  "HangfireSettings": {
    "DashboardPath": "/hangfire"
  },

  "RateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/v1/auth/login",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/v1/internal/device-readings",
        "Period": "1m",
        "Limit": 120
      }
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}